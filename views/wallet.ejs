<%- include('partials/head') %>
<%- include('partials/nav') %>
<section class="container split-page">
  <div class="glass-panel">
    <span class="eyebrow">Wallet</span>
    <h1>Pul kisəsi</h1>
    <p class="muted">Bu MVP-də demo top-up və tam transaction history var. Ödəniş provayderi sonradan env ilə əlavə oluna bilər.</p>
    <form action="/wallet/demo-topup" method="post">
      <button class="btn" type="submit"><%= demoTopupAmount.toFixed(2) %>₼ demo balans artır</button>
    </form>
  </div>
  <div class="glass-panel">
    <h2>Əməliyyatlar</h2>
    <div class="table-list">
      <% tx.forEach(item => { %>
        <div class="table-row">
          <div>
            <strong><%= item.type %></strong>
            <small><%= new Date(item.created_at).toLocaleString('az-AZ') %></small>
          </div>
          <strong class="<%= item.amount >= 0 ? 'text-green' : 'text-red' %>"><%= item.amount.toFixed(2) %>₼</strong>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
