<%- include('partials/head') %>
<%- include('partials/nav') %>
<section class="container page-head">
  <div>
    <span class="eyebrow">History</span>
    <h1>Son qaliblər</h1>
  </div>
</section>
<section class="container cards-2">
  <% winners.forEach(item => { %>
    <article class="glass-panel winner-card">
      <div class="winner-top">
        <div>
          <h3><%= item.winner_name %></h3>
          <p><%= item.room_name %></p>
        </div>
        <strong><%= item.winner_prize.toFixed(2) %>₼</strong>
      </div>
      <p class="muted">Rəqəmlər: <%= item.winning_numbers.join(', ') %></p>
      <% if (item.jackpot_prize) { %><p class="jackpot-text">Jackpot: <%= item.jackpot_prize.toFixed(2) %>₼</p><% } %>
      <small><%= new Date(item.finished_at).toLocaleString('az-AZ') %></small>
    </article>
  <% }) %>
</section>
<%- include('partials/footer') %>
