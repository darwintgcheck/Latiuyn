<%- include('partials/head') %>
<%- include('partials/nav') %>
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">Russian loto · casino style</span>
      <h1><span class="hero-title-accent">Render üzərində işləyən</span> tam canlı Russian Loto kazino saytı.</h1>
      <p class="hero-copy">Mövcud repodakı skeleti analiz edib onu daha peşəkar kazino hissi verən, lobby, countdown, bot dolumu, jackpot, wallet, referral və oyun səhifəsi ilə işlək bir platformaya çevirdim.</p>
      <div class="hero-actions">
        <a href="/register" class="btn">İndi başla</a>
        <a href="/login" class="btn btn-ghost">Demo hesabla yoxla</a>
      </div>
      <ul class="hero-bullets">
        <li>Server-authoritative draw engine və 90 topluq Russian loto axını</li>
        <li>Render üçün hazır konfigurasiya və PostgreSQL dəstəyi</li>
        <li>Database olmasa belə demo üçün in-memory fallback</li>
      </ul>
      <div class="mini-stats">
        <div><strong>5</strong><span>casino otağı</span></div>
        <div><strong>90</strong><span>rəqəmli draw</span></div>
        <div><strong>1.5s</strong><span>canlı ekran yenilənməsi</span></div>
      </div>
    </div>
    <div class="glass-panel hero-card">
      <div class="hero-card-head">
        <div>
          <h3>Canlı lobby</h3>
          <p class="muted">İstifadəçi girməsə belə otaq axını daim hazırdır.</p>
        </div>
        <span class="live-badge"><span class="live-dot"></span> Live</span>
      </div>
      <div class="room-list compact">
        <% rooms.forEach(room => { %>
          <article class="room-item compact-item" style="--room-theme:<%= room.theme %>">
            <div>
              <h4><%= room.name %></h4>
              <p><%= room.ticketLabel %> · <%= helpers.winTypeLabel(room.winType) %></p>
            </div>
            <div class="compact-side">
              <span class="status-pill <%= room.status %>"><%= helpers.statusLabel(room.status) %></span>
              <strong><%= helpers.money(room.pot) %></strong>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>
<section class="container overview-grid">
  <article class="overview-card">
    <h3>Lobby hissi</h3>
    <p class="muted">Otaqların hər birində pot, jackpot, status və timer dinamik yenilənir.</p>
  </article>
  <article class="overview-card">
    <h3>Casino gameplay</h3>
    <p class="muted">Join səhifəsi, canlı oyun səhifəsi və bilet izləmə axını tam qurulub.</p>
  </article>
  <article class="overview-card">
    <h3>Deploy rahatlığı</h3>
    <p class="muted">render.yaml saxlanıldı, üstəlik database yoxdursa app demo rejimdə qalxır.</p>
  </article>
</section>
<section class="container section-grid">
  <div class="glass-panel feature-card"><h3>Canlı Russian Loto axını</h3><p class="muted">Status waiting → starting → started → finished ardıcıllığı serverdə hesablanır və front tərəfdə real vaxt hissi yaradır.</p></div>
  <div class="glass-panel feature-card"><h3>Wallet və referral sistemi</h3><p class="muted">Demo top-up, transaction history və 5% referral bonus axını mövcuddur.</p></div>
  <div class="glass-panel feature-card"><h3>Jackpot otağı</h3><p class="muted">Xüsusi otaqda erkən bitən raund jackpot qazancı da hesablayır və qaliblər cədvəlinə düşür.</p></div>
</section>
<%- include('partials/footer') %>
