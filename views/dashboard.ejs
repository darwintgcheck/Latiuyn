<%- include('partials/head') %>
<%- include('partials/nav') %>
<section class="container page-head">
  <div>
    <span class="eyebrow">Lobby</span>
    <h1>Oyun otaqları</h1>
    <p class="muted">Mövcud saytdakı room kartlarını daha təmiz məlumat arxitekturası ilə yenidən qurdum.</p>
  </div>
</section>
<section class="container room-list" data-lobby>
  <% rooms.forEach(room => { %>
    <article class="room-item" data-room-card data-slug="<%= room.slug %>" style="--room-theme:<%= room.theme %>">
      <div class="room-head">
        <div>
          <h3><%= room.name %></h3>
          <p><%= room.ticketLabel %> • x<%= room.multiplier %> • <%= room.winType === 'one_line' ? 'Bir sətir' : 'Full house' %></p>
        </div>
        <span class="status-pill <%= room.status %>" data-status><%= room.status %></span>
      </div>
      <div class="room-metrics">
        <div><span>Pot</span><strong data-pot><%= room.pot.toFixed(2) %>₼</strong></div>
        <div><span>Jackpot</span><strong data-jackpot><%= room.jackpot !== null ? room.jackpot.toFixed(2) + '₼' : '—' %></strong></div>
        <div><span>Timer</span><strong data-secs data-status-key="<%= room.status %>"><%= room.secsLeft %></strong></div>
      </div>
      <div class="room-foot">
        <small>Son qalib: <%= room.lastWinner || 'hələ yoxdur' %></small>
        <a class="btn btn-sm" href="/rooms/<%= room.slug %>/join">Qoşul</a>
      </div>
    </article>
  <% }) %>
</section>
<script>
  window.__LOBBY__ = true;
</script>
<%- include('partials/footer') %>
